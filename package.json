{
  "name": "cha-sales-tool",
  "private": true,
  "version": "1.0.0",
  "description": "CHA Sales Command Center - static HTML/CSS/JS dashboard",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:js": "eslint js/**/*.js *.js",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:html": "htmlhint \"**/*.html\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "validate": "npm run format:check && npm run lint && npm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.55.0",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "htmlhint": "^1.7.1",
    "http-server": "^14.1.1",
    "prettier": "^3.6.2",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^38.0.0"
  }
}
